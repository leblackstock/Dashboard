# Safe local settings only. Do not put tokens, cookies, auth headers, or auth file contents here.

DASHBOARD_DB_PATH=data/dashboard.db
DASHBOARD_SANITIZED_DIR=data/sanitized
DASHBOARD_API_HOST=127.0.0.1
DASHBOARD_API_PORT=8000
DASHBOARD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional generic Codex home override. Do not commit machine-specific paths in real .env files.
CODEX_HOME=
